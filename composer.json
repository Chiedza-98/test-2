{
  "name": "Chiedza-98/customers-app",
  "description": "Cloud Application Development - Practical Test 2: PHP/PDO customer list",
  "type": "project",
  "license": "MIT",
  "homepage": "https://github.com/Chiedza-98/customers-app",
  "authors": [
    {
      "name":     "Chiedza Nyazema",
      "email":    "everjoynyazema@gmail.com",
      "homepage": "https://github.com/Chiedza-98",
      "role":     "Developer"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "ext-pdo_mysql": "*"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.5"
  },
  "autoload": {
    "psr-4": { "App\\": "src/" }
  },
  "autoload-dev": {
    "psr-4": { "Tests\\": "tests/" }
  },
  "scripts": {
    "lint": "find . -path ./vendor -prune -o -name '*.php' -print0 | xargs -0 -n1 php -l",
    "test": "phpunit --colors=never",
    "test:unit": "phpunit --testsuite=unit",
    "test:integration": "phpunit --testsuite=integration"
  },
  "config": {
    "sort-packages": true,
    "optimize-autoloader": true
  }
}
